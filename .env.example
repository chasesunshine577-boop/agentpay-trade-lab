# App
PORT=4021
APP_MODE=demo

# OKX OnchainOS MCP and REST authentication.
# Create credentials at https://web3.okx.com/onchainos/dev-portal/project
OKX_MCP_URL=https://web3.okx.com/api/v1/onchainos-mcp
OKX_API_BASE_URL=https://web3.okx.com
OKX_ACCESS_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Buyer Agent wallet. Never expose this value to browser code or commit it.
# It must hold USDG or USDT on X Layer for a real x402 payment.
EVM_PRIVATE_KEY=
# Optional public address. If omitted, Live mode derives it from the key.
EVM_WALLET_ADDRESS=
X402_NETWORK=eip155:196
X402_PAYMENT_TOKEN=USDG
X402_MAX_AMOUNT_ATOMIC=10000

# Separate public Solana wallet used only to build swap instructions.
# No Solana private key is needed or accepted by this demo.
SOLANA_WALLET_ADDRESS=

# Optional OpenAI-compatible Chat Completions provider for intent extraction.
# Without these values, the deterministic local planner remains fully usable.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional defaults used by the UI and CLI demo.
DEMO_PAYMENT_WALLET_ADDRESS=0x7E57D0045E3A1A2DcdA3E30B31fB5fB7bE2AF00D
DEMO_SOLANA_WALLET_ADDRESS=J5CBzXpcYn6WR2JBah8zU4Yxct985CAFGwXRcFaX2pbS
DEMO_SOCIAL_PROMPT=筛选 Solana 24h 社媒热度代币，综合市值和成交量，排除貔貅盘、低流动性及开发者清仓，用 25 USDC 构建交易预览。
DEMO_RWA_PROMPT=查询 Solana RWA 代币，综合市值和 24h 成交量选择最强候选，用 25 USDC 构建交易预览。
